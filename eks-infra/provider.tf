terraform {
  required_version = ">= 1.5"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
    helm = {
      source  = "hashicorp/helm"
      version = "~> 2.13"
    }
    kubernetes = {
      source  = "hashicorp/kubernetes"
      version = "~> 2.25"
    }
  }
  backend "s3" {
    bucket       = "terraform-backend-86"
    key          = "roboshop-monitor-infras"
    region       = "us-west-2"
    use_lockfile = true
  }
}
provider "aws" {
  region = "us-west-2"
}

